programa {
  funcao inicio() {
    cadeia valor,positivo,negativo
    escreva("Digite o valor: ")
    leia(valor)
    se (valor > 0) {
      escreva("O valor é lucrativo")
      valor = positivo
    } senao {
      escreva("O valor é prejuízo")
      valor = negativo
    }

    //Valor positivo >=0
    //Valor negativo < 0


  }
}
