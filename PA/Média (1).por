programa {
  funcao inicio() {
    real n1,n2,n3,n4,numero,resultado

    escreva("Digite a nota 1: ")
    leia(n1)
    escreva("Digite a nota 2: ")
    leia(n2)
    escreva("Digite a nota 3: ")
    leia(n3)
    escreva("Digite a nota 4: ")
    leia(n4)
    resultado = (n1+n2+n3+n4/4)
    escreva ("A média final é,", resultado)
  
  }
}