programa {
  funcao inicio() {
    inteiro numero_1,numero_2,numero_3,resultado

    escreva("Digite número 1: ")
    leia(numero_1)
    escreva("Digite número 2: ")
    leia(numero_2)
    escreva("Digite número 3: ")
    leia(numero_3)
    resultado=(numero_1+numero_2+numero_3)
    escreva("A soma dos três é : ", resultado)
  }
}
