programa {
  funcao inicio() {
    inteiro numero_menor,numero_maior,idade

   escreva("Digite sua idade : ")
   leia(idade)
   se (idade > 18) {
     se (idade > 67)
    escreva("Você pode doar sangue ")
   } senao {
    escreva("Você não tem idade apropriada para doar sangue")
   }
  
   }
   
   
  
  }
}
