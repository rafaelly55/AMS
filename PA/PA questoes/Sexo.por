programa {
  funcao inicio() {
   cadeia sexo

   escreva("Digite seu sexo (Feminino ou Masculino): ")
   leia(sexo)

   se (sexo == "Feminino" ou sexo == "feminino")
   escreva("Seu sexo é Feminino")

   senao se (sexo == "Masculino" ou sexo == "masculino")
   escreva("Seu sexo é Masculino")

   senao 
   escreva("Sexo inválido")

  }
}
