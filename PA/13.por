programa {
  funcao inicio() {
    inteiro produtos,resultado1,resultado2,resultado3,resultado4

    escreva("Digite valor dos produtos")
    leia(produtos)

    resultado1=(produtos-produtos*0.10)
    resultado2=(resultado1/3)
    resultado3=(resultado1+resultado1*0.05)
    resultado4=(produtos*0.05)
    escreva("O total a pagar com desconto: ", resultado1)
    escreva("O valor de cada parcela: ")
    escreva("")
    escreva("")



  }
}
