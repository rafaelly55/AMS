programa {
  funcao inicio() {
    inteiro n1,n2,resultado

    escreva("Digite o primeiro número: ")
    leia(n1)
    escreva("Digite o segundo número: ")
    leia(n2)
    resultado=n1 + n2

    se (n1+n2 > 10) {
      escreva("Sucesso!! O número é maior do que 10")
    } senao {
      escreva("Falha... O número é menor do que 10")
    }

    //Resultado maior que 10
    //Resultado menor que 10
     
  }
}
